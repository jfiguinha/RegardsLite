												<object class="sizeritem">
													<border>5</border>
													<flag>wxEXPAND|wxALL</flag>
													<object class="wxComboBox" name="ID_CBVIDEOENCODERHARD">
														<value>none</value>
														<content>
															<item>none</item>
															<item>nvenc</item>
															<item>amf</item>
															<item>qsv</item>
