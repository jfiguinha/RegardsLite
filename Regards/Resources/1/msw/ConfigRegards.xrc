													<border>5</border>
													<flag>wxEXPAND|wxALL</flag>
													<object class="wxComboBox" name="ID_CBVIDEODECODERHARD">
														<value>none</value>
														<content>
															<item>none</item>
															<item>cuda</item>
															<item>qsv</item>
															<item>d3d11va</item>
															<item>dxva2</item>
														</content>
